randomstarts <- 5
randomstarts_cv <- 1
kmeans_starts <- 20
lambda_init <- 1
gamma_init <- 1
# Set up dimensions and centroids
I <- 150
J <- 101
Q <- 2
G <- 4
# smooth smooth
psi1_smooth <- function(t) {
t + sin(pi * t) * exp(-t)
}
psi2_smooth <- function(t) {
cos(3 + pi * t)
